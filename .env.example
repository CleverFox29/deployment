# CraftChain Environment Configuration
# Copy this file to .env and fill in your actual values

# MongoDB Connection String
# Get this from your MongoDB Atlas cluster
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxx.mongodb.net/?appName=Cluster0

# Flask Secret Key for JWT and session management
# Change this to a secure random string in production
SECRET_KEY=your-secret-key-change-this-in-production

# API Server Configuration
API_PORT=5000
API_HOST=0.0.0.0

# Flask Debug Mode (set to False in production)
FLASK_DEBUG=True

# Admin Token for database clearing operations
CLEAR_DB_TOKEN=your-admin-token-here
