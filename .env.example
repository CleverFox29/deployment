# CraftChain Environment Configuration
# Copy this file to .env for local development
# For Railway deployment, set these in Railway's environment variables dashboard

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================
# MongoDB Connection String - Get this from your MongoDB Atlas cluster
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxx.mongodb.net/?appName=Cluster0

# ============================================================================
# SECURITY (REQUIRED)
# ============================================================================
# Flask Secret Key for JWT and session management
# Generate a secure random string (e.g., using: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-change-this-in-production

# Admin Token for database clearing operations
CLEAR_DB_TOKEN=your-admin-token-here

# ============================================================================
# SERVER CONFIGURATION (Optional - Railway sets these automatically)
# ============================================================================
# Port for the API server (Railway will set this automatically via $PORT)
# PORT=5000

# Host binding (default: 0.0.0.0 for Railway)
# HOST=0.0.0.0

# ============================================================================
# ENVIRONMENT (Optional)
# ============================================================================
# Flask environment (development/production)
# Railway automatically sets RAILWAY_ENVIRONMENT
FLASK_ENV=development

# Flask debug mode (should be False in production)
FLASK_DEBUG=False

# ============================================================================
# CORS CONFIGURATION (Optional - for production)
# ============================================================================
# Comma-separated list of allowed origins for CORS
# Example: https://yourdomain.com,https://www.yourdomain.com
# Use * to allow all origins (not recommended for production)
ALLOWED_ORIGINS=*

